<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Monitoring Playstation"
        android:textColor="#1A3A5C"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <!-- AutoCompleteTextView dengan gaya outline Material -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Cari Playstation"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxStrokeColor="#1A3A5C"
        app:boxBackgroundMode="outline"
        android:layout_marginBottom="8dp">

        <AutoCompleteTextView
            android:id="@+id/actCariPs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:completionThreshold="1" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Spinner dengan garis bawah -->
    <Spinner
        android:id="@+id/spStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp" />

    <!-- Tombol Refresh -->
    <Button
        android:id="@+id/btnRefresh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Refresh"
        android:backgroundTint="#1A3A5C"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp" />

    <!-- ProgressBar -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:visibility="gone"
        android:layout_marginBottom="8dp" />

    <!-- Pesan kosong -->
    <TextView
        android:id="@+id/tvKosong"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Data monitoring kosong"
        android:textColor="#888780"
        android:visibility="gone"
        android:layout_marginBottom="8dp" />

    <!-- GridView satu kolom -->
    <GridView
        android:id="@+id/gvMonitoring"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:numColumns="1"
        android:horizontalSpacing="0dp"
        android:verticalSpacing="8dp"
        android:stretchMode="columnWidth" />

</LinearLayout>